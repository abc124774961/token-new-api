APP_PORT=3000
TZ=Asia/Shanghai
SESSION_SECRET=replace-with-pro-session-secret
CRYPTO_SECRET=replace-with-pro-crypto-secret

# Host MySQL example for the server
SQL_DSN=token_new_api:your_password@tcp(host.docker.internal:3306)/token_new_api?charset=utf8mb4&parseTime=true&loc=Local

# If you use an external database service instead, replace the host and port above.
# If you prefer SQLite, comment SQL_DSN and uncomment SQLITE_PATH.
# SQLITE_PATH=/data/new-api.db

# Optional
# LOG_SQL_DSN=
# REDIS_CONN_STRING=redis://host.docker.internal:6379/0
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
NODE_NAME=ecs-node-1
