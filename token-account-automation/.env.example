TZ=Asia/Shanghai

# Service
AUTOMATION_ENV_FILE=
AUTOMATION_PORT=8091
AUTOMATION_LISTEN_ADDR=:8091
AUTOMATION_API_TOKEN=replace-with-main-gateway-event-token
AUTOMATION_WORKER_TOKEN=replace-with-worker-token
AUTOMATION_DESKTOP_TOKEN=replace-with-desktop-client-token
AUTOMATION_SECRET_KEY=replace-with-32-byte-or-longer-secret-key

# Database: sqlite, mysql, or postgres.
AUTOMATION_DB_DRIVER=sqlite
AUTOMATION_DB_DSN=/app/data/token-account-automation.db
AUTOMATION_RUN_MIGRATIONS=true

# Built-in API refresh executor.
AUTOMATION_INTERNAL_EXECUTOR=true
AUTOMATION_INTERNAL_WORKER_ID=internal-api-1
AUTOMATION_INTERNAL_POLL_INTERVAL=2
AUTOMATION_INTERNAL_LEASE_SECONDS=60
AUTOMATION_BROWSER_LOGIN_EXECUTOR=desktop_session

# Main gateway callback. The automation service calls this after obtaining a fresh credential.
AUTOMATION_GATEWAY_CALLBACK_URL=https://gateway.example.com
AUTOMATION_GATEWAY_CALLBACK_TOKEN=replace-with-gateway-callback-token
AUTOMATION_GATEWAY_CALLBACK_TIMEOUT_SECONDS=5

# Browser worker
BROWSER_WORKER_ID=browser-worker-1
BROWSER_HEADLESS=true
BROWSER_POLL_INTERVAL_SECONDS=2
BROWSER_CALLBACK_PORT=1455
BROWSER_LOGIN_TIMEOUT_SECONDS=900
BROWSER_PROFILE_DIR=
