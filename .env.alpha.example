APP_PORT=3001
TZ=Asia/Shanghai
SESSION_SECRET=replace-with-alpha-session-secret
CRYPTO_SECRET=replace-with-alpha-crypto-secret

# Host MySQL example for the alpha server
SQL_DSN=token_new_api_alpha:your_password@tcp(host.docker.internal:3306)/token_new_api_alpha?charset=utf8mb4&parseTime=true&loc=Local

# If you use an external database service instead, replace the host and port above.
# If you prefer SQLite, comment SQL_DSN and uncomment SQLITE_PATH.
# SQLITE_PATH=/data/new-api-alpha.db

# Optional
# LOG_SQL_DSN=
# REDIS_CONN_STRING=redis://host.docker.internal:6379/0
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
RELAY_TIMEOUT=900
STREAMING_TIMEOUT=900
STREAM_SCANNER_MAX_BUFFER_MB=256
CHANNEL_FAILURE_AVOIDANCE_ENABLED=true
CHANNEL_FAILURE_AVOIDANCE_TTL_SECONDS=6
CHANNEL_BALANCE_AUTO_RESUME_ENABLED=true
CHANNEL_BALANCE_RECOVERY_THRESHOLD=0
NODE_NAME=alpha-node-1
