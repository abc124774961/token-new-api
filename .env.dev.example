APP_PORT=3000
FRONTEND_PORT=3000
DEV_FRONTEND_BASE_URL=http://localhost:3000
TZ=Asia/Shanghai
SESSION_SECRET=replace-with-dev-session-secret
CRYPTO_SECRET=replace-with-dev-crypto-secret

# Remote MySQL example
SQL_DSN=token_new_api:your_password@tcp(47.242.10.172:3306)/token_new_api?charset=utf8mb4&parseTime=true&loc=Local

# If you use MySQL on the same host as Docker, replace the host with host.docker.internal.
# SQL_DSN=token_new_api:your_password@tcp(host.docker.internal:3306)/token_new_api?charset=utf8mb4&parseTime=true&loc=Local

# If you prefer SQLite locally, comment SQL_DSN and uncomment SQLITE_PATH.
# SQLITE_PATH=/data/new-api.db

# Optional
# LOG_SQL_DSN=
SKIP_DB_AUTO_MIGRATE=false
SKIP_CODEX_APPLICATION_ENVIRONMENT_SYNC=false
SKIP_MODEL_GATEWAY_RUNTIME_WARMUP=true
# Disabled by default. Enable only after backing up production data.
MODEL_EXECUTION_RECORD_RETENTION_ENABLED=false
MODEL_EXECUTION_RECORD_RETENTION_HOURS=48
MODEL_EXECUTION_RECORD_CLEANUP_INTERVAL_MINUTES=10
MODEL_EXECUTION_RECORD_CLEANUP_BATCH_SIZE=500
MODEL_EXECUTION_RECORD_CLEANUP_MAX_BATCHES=3
REDIS_PORT=6380
REDIS_CONN_STRING=redis://redis:6379/0
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
RELAY_TIMEOUT=900
STREAMING_TIMEOUT=900
STREAM_SCANNER_MAX_BUFFER_MB=256
CHANNEL_FAILURE_AVOIDANCE_ENABLED=true
CHANNEL_FAILURE_AVOIDANCE_TTL_SECONDS=6
CHANNEL_BALANCE_AUTO_RESUME_ENABLED=true
CHANNEL_BALANCE_RECOVERY_THRESHOLD=0
NODE_TYPE=slave
NODE_NAME=dev-node-1

# Token account automation callback used by the main gateway container.
TOKEN_ACCOUNT_AUTOMATION_URL=http://host.docker.internal:18091
TOKEN_ACCOUNT_AUTOMATION_API_TOKEN=replace-with-dev-automation-api-token
TOKEN_ACCOUNT_AUTOMATION_CALLBACK_TOKEN=replace-with-dev-automation-callback-token
TOKEN_ACCOUNT_AUTOMATION_TIMEOUT_SECONDS=5

# Token account automation service, loaded by:
#   cd token-account-automation && AUTOMATION_ENV_FILE=../.env.dev go run ./cmd/server
AUTOMATION_LISTEN_ADDR=:18091
AUTOMATION_API_TOKEN=${TOKEN_ACCOUNT_AUTOMATION_API_TOKEN}
AUTOMATION_WORKER_TOKEN=replace-with-dev-automation-worker-token
AUTOMATION_DESKTOP_TOKEN=replace-with-dev-desktop-client-token
AUTOMATION_SECRET_KEY=replace-with-32-byte-or-longer-dev-secret-key
AUTOMATION_DB_DRIVER=sqlite
AUTOMATION_DB_DSN=./data/token-account-automation-dev.db
AUTOMATION_RUN_MIGRATIONS=true
AUTOMATION_INTERNAL_EXECUTOR=true
AUTOMATION_INTERNAL_WORKER_ID=internal-api-dev-1
AUTOMATION_INTERNAL_POLL_INTERVAL=2
AUTOMATION_INTERNAL_LEASE_SECONDS=60
AUTOMATION_BROWSER_LOGIN_EXECUTOR=desktop_session
AUTOMATION_GATEWAY_CALLBACK_URL=http://127.0.0.1:3001
AUTOMATION_GATEWAY_CALLBACK_TOKEN=${TOKEN_ACCOUNT_AUTOMATION_CALLBACK_TOKEN}
AUTOMATION_GATEWAY_CALLBACK_TIMEOUT_SECONDS=5
BROWSER_WORKER_ID=browser-worker-dev-1
BROWSER_HEADLESS=false
BROWSER_POLL_INTERVAL_SECONDS=2
BROWSER_CALLBACK_PORT=1455
BROWSER_LOGIN_TIMEOUT_SECONDS=900
BROWSER_PROFILE_DIR=
